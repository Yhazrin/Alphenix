# Database
POSTGRES_DB=alphenix
POSTGRES_USER=alphenix
POSTGRES_PASSWORD=alphenix
POSTGRES_PORT=5432
DATABASE_URL=postgres://alphenix:alphenix@localhost:5432/alphenix?sslmode=disable

# Server
PORT=8080
JWT_SECRET=change-me-in-production
APP_ENV=development
ALLOW_DEV_MASTER_CODE=false
ALPHENIX_SERVER_URL=ws://localhost:8080/ws
ALPHENIX_APP_URL=http://localhost:3000
ALPHENIX_DAEMON_CONFIG=
ALPHENIX_WORKSPACE_ID=
ALPHENIX_DAEMON_ID=
ALPHENIX_DAEMON_DEVICE_NAME=
ALPHENIX_DAEMON_POLL_INTERVAL=3s
ALPHENIX_DAEMON_HEARTBEAT_INTERVAL=15s
ALPHENIX_CODEX_PATH=codex
ALPHENIX_CODEX_MODEL=
ALPHENIX_CODEX_WORKDIR=
ALPHENIX_CODEX_TIMEOUT=20m

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@alphenix.ai

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# S3 / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=alphenix/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=

# Frontend
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Remote API (optional) — set to proxy local frontend to a remote backend
# Leave empty to use local backend (localhost:8080)
# REMOTE_API_URL=https://alphenix-api.copilothub.ai
